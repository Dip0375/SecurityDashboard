# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  SAFE TO COMMIT (no real secrets here)
# Copy this to .env.local and fill in real values for local development.
# ─────────────────────────────────────────────────────────────────────────────

# Dashboard login accounts (JSON array).
# ⚠  This is for the dashboard login screen only — NOT for AWS credentials.
VITE_DEFAULT_CREDENTIALS='[{"email":"admin@yourcompany.com","password":"ChangeMe!","role":"admin","name":"Admin"}]'

# Set to "false" in production to call real AWS APIs via /api/aws-query.
VITE_MOCK_AWS=true

# ─── AWS Account Credentials (SERVER-SIDE ONLY) ───────────────────────────────
# These variables are set in Vercel → Settings → Environment Variables.
# They are NEVER prefixed with VITE_ and NEVER go in .env.local.
#
# Replace 123456789012 with your real 12-digit AWS account ID.
# AWS_ACCOUNT_123456789012_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_ACCOUNT_123456789012_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_ACCOUNT_123456789012_REGION=us-east-1
