# ── Build outputs ─────────────────────────────────────────────────────────────
dist
dist-ssr

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules

# ── Logs ─────────────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Environment files  (⚠ NEVER commit these) ─────────────────────────────────
.env
.env.*
.env.local
.env.*.local
!.env.example          # the example template is safe to commit

# ── AWS credentials  (belt-and-suspenders – also covered by .env.*) ───────────
# If someone accidentally creates these files, block them hard.
credentials
.aws/
aws-credentials*
*_access_key*
*_secret_key*
*.pem
*.p12

# ── Editor / OS ───────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
